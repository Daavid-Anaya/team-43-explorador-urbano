# Supabase Configuration
# These values are safe to expose to the browser/client

# Supabase project URL (public)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (public, safe for client use)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# -----------------------------------------------------------------------------
# IMPORTANT: Service Role Key Security
# -----------------------------------------------------------------------------
# The SUPABASE_SERVICE_ROLE_KEY provides full database access and MUST NEVER
# be exposed to the client. Do NOT add it to this file with VITE_ prefix.
#
# For server-side operations (if needed in future):
# - Store it in Vercel environment variables (not exposed to client)
# - Use it only in server-side functions or API routes
# - Never commit real values to git
#
# Example (server-side only, no VITE_ prefix):
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
#
# The client uses only VITE_SUPABASE_ANON_KEY which has restricted permissions
# enforced by Row Level Security (RLS) policies.
# -----------------------------------------------------------------------------
